<ResourceDictionary xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
                    xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml">

    <!-- Color Palette (from design mockup, oklch converted to hex) -->
    <Color x:Key="BgColor">#F7FAF8</Color>
    <Color x:Key="BgSidebarColor">#EFF4F1</Color>
    <Color x:Key="BgHoverColor">#E5ECE8</Color>
    <Color x:Key="BgSelectedColor">#E0E9E3</Color>
    <Color x:Key="BorderColor">#D6DDD8</Color>
    <Color x:Key="AccentColor">#3A8A5C</Color>
    <Color x:Key="TextColor">#1E2D23</Color>
    <Color x:Key="Text2Color">#586B5E</Color>
    <Color x:Key="Text3Color">#939F96</Color>
    <Color x:Key="TitlebarColor">#EAF0EC</Color>
    <Color x:Key="DangerColor">#E05C5C</Color>

    <SolidColorBrush x:Key="BgBrush" Color="{StaticResource BgColor}" />
    <SolidColorBrush x:Key="BgSidebarBrush" Color="{StaticResource BgSidebarColor}" />
    <SolidColorBrush x:Key="BgHoverBrush" Color="{StaticResource BgHoverColor}" />
    <SolidColorBrush x:Key="BgSelectedBrush" Color="{StaticResource BgSelectedColor}" />
    <SolidColorBrush x:Key="BorderBrush" Color="{StaticResource BorderColor}" />
    <SolidColorBrush x:Key="AccentBrush" Color="{StaticResource AccentColor}" />
    <SolidColorBrush x:Key="TextBrush" Color="{StaticResource TextColor}" />
    <SolidColorBrush x:Key="Text2Brush" Color="{StaticResource Text2Color}" />
    <SolidColorBrush x:Key="Text3Brush" Color="{StaticResource Text3Color}" />
    <SolidColorBrush x:Key="TitlebarBrush" Color="{StaticResource TitlebarColor}" />
    <SolidColorBrush x:Key="DangerBrush" Color="{StaticResource DangerColor}" />

    <!-- Scrollbar Style -->
    <Style x:Key="ThinScrollBar" TargetType="ScrollViewer">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ScrollViewer">
                    <Grid>
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition />
                            <ColumnDefinition Width="Auto" />
                        </Grid.ColumnDefinitions>
                        <ScrollContentPresenter Grid.Column="0" />
                        <ScrollBar Grid.Column="1" Name="PART_VerticalScrollBar"
                                   Value="{TemplateBinding VerticalOffset}"
                                   Maximum="{TemplateBinding ScrollableHeight}"
                                   ViewportSize="{TemplateBinding ViewportHeight}"
                                   Visibility="{TemplateBinding ComputedVerticalScrollBarVisibility}"
                                   Width="4" Opacity="0.4" />
                    </Grid>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Note List Item Style -->
    <Style x:Key="NoteListItem" TargetType="ListBoxItem">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="ListBoxItem">
                    <Border x:Name="Bd" Padding="12,8" BorderThickness="0,0,0,1"
                            BorderBrush="{StaticResource BorderBrush}"
                            Background="Transparent">
                        <Grid>
                            <Border x:Name="Indicator" Width="2.5" HorizontalAlignment="Left"
                                    Margin="-12,0,0,0" CornerRadius="0,2,2,0"
                                    Background="{StaticResource AccentBrush}" Opacity="0" />
                            <ContentPresenter />
                        </Grid>
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                        </Trigger>
                        <Trigger Property="IsSelected" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgSelectedBrush}" />
                            <Setter TargetName="Indicator" Property="Opacity" Value="1" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Flat Button Style -->
    <Style x:Key="FlatButton" TargetType="Button">
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Padding" Value="6,4" />
        <Setter Property="Cursor" Value="Hand" />
        <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="{TemplateBinding Background}"
                            CornerRadius="4" Padding="{TemplateBinding Padding}">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- New Note Button -->
    <Style x:Key="NewNoteButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Width" Value="24" />
        <Setter Property="Height" Value="24" />
        <Setter Property="FontSize" Value="14" />
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Width="24" Height="24" CornerRadius="5"
                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                            Background="{StaticResource BgBrush}" Cursor="Hand">
                        <TextBlock Text="+" FontSize="14" Foreground="{StaticResource Text2Brush}"
                                   HorizontalAlignment="Center" VerticalAlignment="Center"
                                   Margin="0,-2,0,0" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="{StaticResource BgHoverBrush}" />
                            <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Danger Button -->
    <Style x:Key="DangerButton" TargetType="Button" BasedOn="{StaticResource FlatButton}">
        <Setter Property="Template">
            <Setter.Value>
                <ControlTemplate TargetType="Button">
                    <Border x:Name="Bd" Background="Transparent" CornerRadius="4" Padding="6,4" Cursor="Hand">
                        <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                    </Border>
                    <ControlTemplate.Triggers>
                        <Trigger Property="IsMouseOver" Value="True">
                            <Setter TargetName="Bd" Property="Background" Value="#FFF0F0" />
                        </Trigger>
                    </ControlTemplate.Triggers>
                </ControlTemplate>
            </Setter.Value>
        </Setter>
    </Style>

    <!-- Title Input Style -->
    <Style x:Key="TitleInput" TargetType="TextBox">
        <Setter Property="BorderThickness" Value="0" />
        <Setter Property="Background" Value="Transparent" />
        <Setter Property="FontFamily" Value="Noto Serif SC, SimSun, serif" />
        <Setter Property="FontSize" Value="13" />
        <Setter Property="FontWeight" Value="Medium" />
        <Setter Property="Foreground" Value="{StaticResource TextBrush}" />
        <Setter Property="CaretBrush" Value="{StaticResource TextBrush}" />
        <Setter Property="Padding" Value="0" />
        <Setter Property="VerticalContentAlignment" Value="Center" />
    </Style>

</ResourceDictionary>
