<Window x:Class="花笺.Views.MainWindow"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:avalonEdit="http://icsharpcode.net/sharpdevelop/avalonedit"
        xmlns:helpers="clr-namespace:花笺.Helpers"
        xmlns:vm="clr-namespace:花笺.ViewModels"
        xmlns:wv2="clr-namespace:Microsoft.Web.WebView2.Wpf;assembly=Microsoft.Web.WebView2.Wpf"
        mc:Ignorable="d"
        Title="花笺" Height="780" Width="1200"
        Background="{StaticResource BgBrush}"
        WindowStartupLocation="CenterScreen">

    <Window.Resources>
        <helpers:NoteTitleConverter x:Key="NoteTitleConverter" />
        <helpers:NoteDateConverter x:Key="NoteDateConverter" />
        <helpers:BoolToVisibilityConverter x:Key="BoolToVis" />
        <helpers:InverseBoolToVisibilityConverter x:Key="InvBoolToVis" />
        <helpers:SavedStatusConverter x:Key="SavedStatusConverter" />
        <helpers:SavedStatusColorConverter x:Key="SavedStatusColorConverter" />
    </Window.Resources>

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="38" />
            <RowDefinition Height="*" />
        </Grid.RowDefinitions>

        <!-- Titlebar -->
        <Border Grid.Row="0" Background="{StaticResource TitlebarBrush}"
                BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
            <Grid>
                <TextBlock Text="花  笺"
                           FontFamily="Noto Serif SC, SimSun, serif"
                           FontSize="12" Foreground="{StaticResource Text2Brush}"
                           HorizontalAlignment="Center" VerticalAlignment="Center" />

                <!-- Quick Note button -->
                <Button HorizontalAlignment="Right" VerticalAlignment="Center" Margin="0,0,14,0"
                        Command="{Binding QuickNoteCommand}" Cursor="Hand"
                        ToolTip="Ctrl+Space 呼出快速记录">
                    <Button.Template>
                        <ControlTemplate TargetType="Button">
                            <Border x:Name="Bd" Padding="8,3" CornerRadius="4"
                                    BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                    Background="{StaticResource BgBrush}">
                                <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                    <TextBlock Text="快速记录" FontSize="11"
                                               FontFamily="Noto Sans SC, sans-serif"
                                               Foreground="{StaticResource Text2Brush}" />
                                    <Border Margin="6,0,0,0" Padding="3,0" CornerRadius="2"
                                            Background="{StaticResource BgSidebarBrush}"
                                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}">
                                        <TextBlock Text="Ctrl+Space" FontSize="9"
                                                   Foreground="{StaticResource Text3Brush}" />
                                    </Border>
                                </StackPanel>
                            </Border>
                            <ControlTemplate.Triggers>
                                <Trigger Property="IsMouseOver" Value="True">
                                    <Setter TargetName="Bd" Property="BorderBrush" Value="{StaticResource AccentBrush}" />
                                </Trigger>
                            </ControlTemplate.Triggers>
                        </ControlTemplate>
                    </Button.Template>
                </Button>
            </Grid>
        </Border>

        <!-- Main Content -->
        <Grid Grid.Row="1">
            <Grid.ColumnDefinitions>
                <ColumnDefinition Width="220" />
                <ColumnDefinition Width="*" />
            </Grid.ColumnDefinitions>

            <!-- Sidebar -->
            <Border Grid.Column="0" Background="{StaticResource BgSidebarBrush}"
                    BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,1,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="Auto" />
                    </Grid.RowDefinitions>

                    <!-- Sidebar Header -->
                    <Border Grid.Row="0" Padding="12,10,12,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <TextBlock Text="笔记"
                                       FontFamily="Noto Serif SC, SimSun, serif"
                                       FontSize="15" FontWeight="Medium"
                                       Foreground="{StaticResource AccentBrush}"
                                       VerticalAlignment="Center" />
                            <Button DockPanel.Dock="Right" HorizontalAlignment="Right"
                                    Style="{StaticResource NewNoteButton}"
                                    Command="{Binding NewNoteCommand}"
                                    ToolTip="新建笔记" />
                        </DockPanel>
                    </Border>

                    <!-- Note List -->
                    <ListBox Grid.Row="1" x:Name="NoteList"
                             ItemsSource="{Binding Notes}"
                             SelectedItem="{Binding SelectedNote}"
                             Background="Transparent"
                             BorderThickness="0"
                             ScrollViewer.HorizontalScrollBarVisibility="Disabled"
                             ItemContainerStyle="{StaticResource NoteListItem}">
                        <ListBox.ItemTemplate>
                            <DataTemplate>
                                <StackPanel>
                                    <TextBlock Text="{Binding Converter={StaticResource NoteTitleConverter}}"
                                               FontSize="12" FontWeight="Medium"
                                               Foreground="{StaticResource TextBrush}"
                                               TextTrimming="CharacterEllipsis" />
                                    <TextBlock Text="{Binding Converter={StaticResource NoteDateConverter}}"
                                               FontSize="10" Foreground="{StaticResource Text3Brush}"
                                               Margin="0,3,0,0" />
                                </StackPanel>
                            </DataTemplate>
                        </ListBox.ItemTemplate>
                    </ListBox>

                    <!-- Sidebar Footer -->
                    <Border Grid.Row="2" Padding="12,8"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0">
                        <TextBlock FontSize="10" Foreground="{StaticResource Text3Brush}">
                            <TextBlock.Text>
                                <MultiBinding StringFormat="{}{0} 篇笔记">
                                    <Binding Path="Notes.Count" />
                                </MultiBinding>
                            </TextBlock.Text>
                        </TextBlock>
                    </Border>
                </Grid>
            </Border>

            <!-- Editor Area -->
            <Grid Grid.Column="1">
                <!-- Has Note Selected -->
                <Grid Visibility="{Binding HasSelectedNote, Converter={StaticResource BoolToVis}}">
                    <Grid.RowDefinitions>
                        <RowDefinition Height="38" />
                        <RowDefinition Height="*" />
                        <RowDefinition Height="24" />
                    </Grid.RowDefinitions>

                    <!-- Editor Toolbar -->
                    <Border Grid.Row="0" Padding="16,0"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,0,0,1">
                        <DockPanel>
                            <!-- Title Input -->
                            <TextBox Style="{StaticResource TitleInput}"
                                     Text="{Binding NoteTitle, UpdateSourceTrigger=PropertyChanged}"
                                     VerticalAlignment="Center" />

                            <!-- Right side actions -->
                            <StackPanel DockPanel.Dock="Right" Orientation="Horizontal"
                                        HorizontalAlignment="Right" VerticalAlignment="Center">

                                <!-- Markdown Toolbar -->
                                <StackPanel Orientation="Horizontal" Margin="0,0,4,0"
                                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}">
                                    <Button Style="{StaticResource FlatButton}" ToolTip="标题 (Ctrl+1)"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="heading"
                                            Padding="4,4">
                                        <TextBlock Text="H" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="粗体 (Ctrl+B)"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="bold"
                                            Padding="4,4">
                                        <TextBlock Text="B" FontSize="12" FontWeight="Bold" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="斜体 (Ctrl+I)"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="italic"
                                            Padding="4,4">
                                        <TextBlock Text="I" FontSize="12" FontStyle="Italic" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="代码"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="code"
                                            Padding="4,4">
                                        <TextBlock Text="{}{&lt;/&gt;}" FontSize="10" FontFamily="Consolas" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="列表"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="list"
                                            Padding="4,4">
                                        <TextBlock Text="&#xE8FD;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="引用"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="quote"
                                            Padding="4,4">
                                        <TextBlock Text="&#xE9B1;" FontFamily="Segoe MDL2 Assets" FontSize="12" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                    <Button Style="{StaticResource FlatButton}" ToolTip="分割线"
                                            Command="{Binding InsertMarkdownCommand}" CommandParameter="hr"
                                            Padding="4,4">
                                        <TextBlock Text="—" FontSize="12" Foreground="{StaticResource Text2Brush}" />
                                    </Button>
                                </StackPanel>

                                <Border Width="1" Height="16" Background="{StaticResource BorderBrush}" Margin="4,0" />

                                <!-- Mode Toggle -->
                                <Border Background="{StaticResource BgSidebarBrush}"
                                        CornerRadius="5" BorderThickness="1" BorderBrush="{StaticResource BorderBrush}"
                                        Padding="2" Margin="0,0,8,0">
                                    <StackPanel Orientation="Horizontal">
                                        <Button x:Name="EditModeBtn" Command="{Binding SwitchToEditCommand}"
                                                Padding="8,2" Cursor="Hand" FontSize="11" FontFamily="Noto Sans SC, sans-serif">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditMode}" Value="True">
                                                            <Setter Property="Background" Value="{StaticResource BgBrush}" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="编辑" />
                                        </Button>
                                        <Button x:Name="PreviewModeBtn" Command="{Binding SwitchToPreviewCommand}"
                                                Padding="8,2" Cursor="Hand" FontSize="11" FontFamily="Noto Sans SC, sans-serif">
                                            <Button.Style>
                                                <Style TargetType="Button">
                                                    <Setter Property="BorderThickness" Value="0" />
                                                    <Setter Property="Foreground" Value="{StaticResource Text2Brush}" />
                                                    <Setter Property="Background" Value="Transparent" />
                                                    <Setter Property="Template">
                                                        <Setter.Value>
                                                            <ControlTemplate TargetType="Button">
                                                                <Border x:Name="Bd" Background="{TemplateBinding Background}"
                                                                        CornerRadius="3" Padding="{TemplateBinding Padding}">
                                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                                </Border>
                                                            </ControlTemplate>
                                                        </Setter.Value>
                                                    </Setter>
                                                    <Style.Triggers>
                                                        <DataTrigger Binding="{Binding IsEditMode}" Value="False">
                                                            <Setter Property="Background" Value="{StaticResource BgBrush}" />
                                                            <Setter Property="Foreground" Value="{StaticResource AccentBrush}" />
                                                        </DataTrigger>
                                                    </Style.Triggers>
                                                </Style>
                                            </Button.Style>
                                            <TextBlock Text="预览" />
                                        </Button>
                                    </StackPanel>
                                </Border>

                                <Border Width="1" Height="16" Background="{StaticResource BorderBrush}" Margin="0,0,8,0" />

                                <!-- Pin Note Button -->
                                <Button Style="{StaticResource FlatButton}"
                                        Command="{Binding PinNoteCommand}"
                                        ToolTip="钉为磁贴" Foreground="{StaticResource Text3Brush}"
                                        Margin="0,0,4,0">
                                    <TextBlock Text="&#xE718;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                                </Button>

                                <!-- Delete Button -->
                                <Button Style="{StaticResource DangerButton}"
                                        Command="{Binding RequestDeleteCommand}"
                                        ToolTip="删除此笔记" Foreground="{StaticResource Text3Brush}">
                                    <TextBlock Text="&#xE74D;" FontFamily="Segoe MDL2 Assets" FontSize="13" />
                                </Button>
                            </StackPanel>
                        </DockPanel>
                    </Border>

                    <!-- Editor / Preview Body -->
                    <Grid Grid.Row="1">
                        <!-- AvalonEdit Editor -->
                        <avalonEdit:TextEditor
                            x:Name="Editor"
                            Visibility="{Binding IsEditMode, Converter={StaticResource BoolToVis}}"
                            helpers:AvalonEditBehavior.BoundText="{Binding EditorContent, Mode=TwoWay, UpdateSourceTrigger=PropertyChanged}"
                            FontFamily="Noto Serif SC, SimSun, Consolas"
                            FontSize="13"
                            Padding="24,20"
                            Background="{StaticResource BgBrush}"
                            Foreground="{StaticResource TextBrush}"
                            ShowLineNumbers="False"
                            WordWrap="True"
                            HorizontalScrollBarVisibility="Disabled"
                            VerticalScrollBarVisibility="Auto"
                            BorderThickness="0" />

                        <!-- Markdown Preview -->
                        <wv2:WebView2 x:Name="PreviewBrowser"
                                      Visibility="{Binding IsEditMode, Converter={StaticResource InvBoolToVis}}"
                                      DefaultBackgroundColor="Transparent" />

                        <!-- Delete Confirm Overlay -->
                        <Border Visibility="{Binding ShowDeleteConfirm, Converter={StaticResource BoolToVis}}"
                                Background="#DDFFFFFF">
                            <StackPanel HorizontalAlignment="Center" VerticalAlignment="Center">
                                <TextBlock Text="确认删除此笔记？此操作不可撤销。"
                                           FontSize="13" Foreground="{StaticResource TextBrush}"
                                           HorizontalAlignment="Center" Margin="0,0,0,12" />
                                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                                    <Button Content="取消" Padding="16,5" Margin="0,0,8,0"
                                            Style="{StaticResource FlatButton}"
                                            Command="{Binding CancelDeleteCommand}"
                                            BorderThickness="1" BorderBrush="{StaticResource BorderBrush}" />
                                    <Button Content="删除" Padding="16,5"
                                            Background="{StaticResource DangerBrush}"
                                            Foreground="White" BorderThickness="0" Cursor="Hand"
                                            Command="{Binding ConfirmDeleteCommand}">
                                        <Button.Template>
                                            <ControlTemplate TargetType="Button">
                                                <Border Background="{TemplateBinding Background}"
                                                        CornerRadius="5" Padding="{TemplateBinding Padding}"
                                                        Cursor="Hand">
                                                    <ContentPresenter HorizontalAlignment="Center" VerticalAlignment="Center" />
                                                </Border>
                                            </ControlTemplate>
                                        </Button.Template>
                                    </Button>
                                </StackPanel>
                            </StackPanel>
                        </Border>
                    </Grid>

                    <!-- Status Bar -->
                    <Border Grid.Row="2" Background="{StaticResource BgSidebarBrush}"
                            BorderBrush="{StaticResource BorderBrush}" BorderThickness="0,1,0,0"
                            Padding="16,0">
                        <DockPanel>
                            <StackPanel Orientation="Horizontal" VerticalAlignment="Center">
                                <Ellipse Width="5" Height="5"
                                         Fill="{Binding IsSaved, Converter={StaticResource SavedStatusColorConverter}}" />
                                <TextBlock Text="{Binding IsSaved, Converter={StaticResource SavedStatusConverter}}"
                                           FontSize="10" Foreground="{StaticResource Text3Brush}" Margin="6,0,0,0" />
                                <TextBlock Text=" · " FontSize="10" Foreground="{StaticResource Text3Brush}" />
                                <TextBlock FontSize="10" Foreground="{StaticResource Text3Brush}">
                                    <TextBlock.Text>
                                        <MultiBinding StringFormat="{}{0} 字">
                                            <Binding Path="WordCount" />
                                        </MultiBinding>
                                    </TextBlock.Text>
                                </TextBlock>
                                <TextBlock Text=" · " FontSize="10" Foreground="{StaticResource Text3Brush}" />
                                <TextBlock Text="Markdown" FontSize="10" Foreground="{StaticResource Text3Brush}" />
                            </StackPanel>
                            <TextBlock Text="{Binding StatusTime}" FontSize="10"
                                       Foreground="{StaticResource Text3Brush}"
                                       DockPanel.Dock="Right" HorizontalAlignment="Right"
                                       VerticalAlignment="Center" />
                        </DockPanel>
                    </Border>
                </Grid>

                <!-- Empty State -->
                <StackPanel Visibility="{Binding HasSelectedNote, Converter={StaticResource InvBoolToVis}}"
                            HorizontalAlignment="Center" VerticalAlignment="Center">
                    <TextBlock Text="笺" FontFamily="Noto Serif SC, SimSun, serif"
                               FontSize="32" Foreground="{StaticResource Text3Brush}"
                               Opacity="0.3" HorizontalAlignment="Center" />
                    <TextBlock Text="选择或新建一篇笔记"
                               FontSize="12" Foreground="{StaticResource Text3Brush}"
                               HorizontalAlignment="Center" Margin="0,8,0,0" />
                </StackPanel>
            </Grid>
        </Grid>
    </Grid>
</Window>
